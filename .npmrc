# Hoist tailwindcss so Turbopack's CSS resolver can find it from
# any pnpm peer-resolution context (e.g. next resolved with @playwright/test).
# Without this, `@import "tailwindcss"` in globals.css fails when
# Next dev is spawned by Playwright's webServer.
public-hoist-pattern[]=tailwindcss
public-hoist-pattern[]=@tailwindcss/*
