{
  "name": "calaire-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "node --test 'lib/**/*.test.ts'",
    "test:e2e": "playwright test",
    "test:e2e:auth:manual": "PLAYWRIGHT_AUTH_MODE=manual playwright test --project=manual-auth",
    "test:e2e:start": "PLAYWRIGHT_START_SERVER=1 playwright test",
    "test:e2e:ui": "playwright test --ui",
    "sgc:extract-seeds": "node scripts/extract-sgc-seeds.mjs",
    "sgc:import-seeds": "node scripts/import-sgc-seeds.mjs",
    "sgc:provision-drive": "node scripts/provision-sgc-drive.mjs",
    "sgc:validate-drive": "node scripts/validate-sgc-drive.mjs",
    "sgc:drive-oauth:url": "node scripts/google-drive-oauth.mjs url",
    "sgc:drive-oauth:token": "node scripts/google-drive-oauth.mjs token",
    "sgc:upload-document-versions": "node scripts/upload-sgc-document-versions.mjs",
    "release": "node scripts/release.mjs"
  },
  "dependencies": {
    "@workos-inc/authkit-nextjs": "^3.0.1",
    "@workos-inc/node": "8.13.0",
    "convex": "^1.38.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
